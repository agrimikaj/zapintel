# ── OpenRouter (LLM) ────────────────────────────────────────────────
# All LLM + web-search calls in the bulk-outreach feature route through
# this single key. Sonar search uses `perplexity/sonar-pro` via the same
# OpenRouter endpoint — no separate Perplexity key needed.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SONAR_MODEL=perplexity/sonar-pro

# ── Lusha (verified email enrichment — OPTIONAL) ────────────────────
# When set, the messaging CSV fills the `email` column with VERIFIED
# emails from Lusha for accepted leads that have none. Leave blank to
# skip email enrichment entirely (the column stays empty — never guessed).
# Website + LinkedIn enrichment do NOT need this key (they use Sonar).
# Get an API key from the Lusha dashboard → API.
LUSHA_API_KEY=

# ── Supabase (auth + reports DB) ────────────────────────────────────
# Get these from Supabase dashboard → Project Settings → API.
# - URL + anon key are also exposed to the browser via NEXT_PUBLIC_*
# - service-role key is server-only; never ship to browser code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Access allowlist ────────────────────────────────────────────────
# Comma-separated emails allowed to log in via the Supabase magic-link
# flow. Lowercase, no spaces. Empty value = nobody can log in via that
# path. Has no effect when simple auth (below) is enabled.
WHITELIST_EMAILS=sarah@zapsight.co.uk

# ── Simple shared-password auth (default) ──────────────────────────
# When APP_PASSWORD is set, the middleware uses simple-auth instead of
# Supabase: anyone with the password gets in, server-signed cookie keeps
# the session for 30 days. Used while Supabase is not yet provisioned
# for this deployment.
#
# Generate the secret with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_PASSWORD=
APP_SESSION_SECRET=
